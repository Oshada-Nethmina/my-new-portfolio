<svg xmlns="http://www.w3.org/2000/svg" width="280" height="340" viewBox="0 0 280 340">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="100%" style="stop-color:#16213e"/>
    </linearGradient>
    <linearGradient id="avatar" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1"/>
      <stop offset="100%" style="stop-color:#8b5cf6"/>
    </linearGradient>
    <linearGradient id="body" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#312e81"/>
      <stop offset="100%" style="stop-color:#1e1b4b"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <radialGradient id="radial1" cx="30%" cy="30%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:transparent"/>
    </radialGradient>
    <radialGradient id="radial2" cx="70%" cy="70%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0.25"/>
      <stop offset="100%" style="stop-color:transparent"/>
    </radialGradient>
  </defs>

  <!-- Background -->
  <rect width="280" height="340" fill="url(#bg)" rx="18"/>
  <rect width="280" height="340" fill="url(#radial1)" rx="18"/>
  <rect width="280" height="340" fill="url(#radial2)" rx="18"/>

  <!-- Grid lines -->
  <line x1="0" y1="85" x2="280" y2="85" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>
  <line x1="0" y1="170" x2="280" y2="170" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>
  <line x1="0" y1="255" x2="280" y2="255" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>
  <line x1="70" y1="0" x2="70" y2="340" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>
  <line x1="140" y1="0" x2="140" y2="340" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>
  <line x1="210" y1="0" x2="210" y2="340" stroke="#6366f1" stroke-opacity="0.08" stroke-width="1"/>

  <!-- Body/shoulders -->
  <ellipse cx="140" cy="310" rx="100" ry="60" fill="url(#body)" opacity="0.9"/>

  <!-- Neck -->
  <rect x="120" y="205" width="40" height="40" rx="8" fill="#c9a882"/>

  <!-- Head -->
  <ellipse cx="140" cy="180" rx="58" ry="68" fill="#d4a574"/>

  <!-- Hair -->
  <ellipse cx="140" cy="128" rx="60" ry="36" fill="#2d1a0e"/>
  <rect x="84" y="128" width="18" height="44" rx="9" fill="#2d1a0e"/>
  <rect x="178" y="128" width="18" height="44" rx="9" fill="#2d1a0e"/>

  <!-- Face features -->
  <!-- Eyes -->
  <ellipse cx="118" cy="178" rx="9" ry="10" fill="white"/>
  <ellipse cx="162" cy="178" rx="9" ry="10" fill="white"/>
  <ellipse cx="119" cy="179" rx="5.5" ry="6" fill="#3b2314"/>
  <ellipse cx="163" cy="179" rx="5.5" ry="6" fill="#3b2314"/>
  <circle cx="121" cy="177" r="1.5" fill="white"/>
  <circle cx="165" cy="177" r="1.5" fill="white"/>

  <!-- Eyebrows -->
  <path d="M 106 166 Q 118 162 130 166" stroke="#2d1a0e" stroke-width="3" fill="none" stroke-linecap="round"/>
  <path d="M 150 166 Q 162 162 174 166" stroke="#2d1a0e" stroke-width="3" fill="none" stroke-linecap="round"/>

  <!-- Nose -->
  <path d="M 140 185 Q 133 198 136 202 Q 140 205 144 202 Q 147 198 140 185" fill="#c09060" fill-opacity="0.5"/>

  <!-- Smile -->
  <path d="M 122 215 Q 140 226 158 215" stroke="#a07040" stroke-width="2.5" fill="none" stroke-linecap="round"/>

  <!-- Shirt/collar -->
  <path d="M 80 270 Q 100 240 120 235 L 140 245 L 160 235 Q 180 240 200 270 Q 200 340 80 340 Z" fill="#312e81"/>
  <path d="M 120 235 L 140 255 L 160 235" stroke="#4338ca" stroke-width="1.5" fill="none"/>

  <!-- Glow ring at bottom -->
  <ellipse cx="140" cy="330" rx="90" ry="8" fill="#6366f1" fill-opacity="0.12" filter="url(#glow)"/>

  <!-- Initials overlay (subtle) -->
  <text x="140" y="320" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" font-weight="700" fill="#6366f1" fill-opacity="0.4" letter-spacing="3">ALEX MORGAN</text>
</svg>
